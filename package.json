{
  "name": "loom-ai-monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "catalog:local": "node ./scripts/catalog-local.mjs",
    "catalog:official": "node ./scripts/catalog-official.mjs",
    "cleanup": "node scripts/cleanup.mjs",
    "cleanup:all": "node scripts/cleanup.mjs --del-lock",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@loom/eslint-config": "workspace:*",
    "@loom/typescript-config": "workspace:*",
    "eslint": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  }
}
